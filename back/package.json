{
  "name": "back",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "dotenvx run -- node --watch --watch-preserve-output -r ts-node/register index.ts",
    "build": "dotenvx run -- prisma generate && tsc",
    "start": "dotenvx run -- node dist/index.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:push": "dotenvx run -- prisma db push",
    "generate": "dotenvx run -- prisma generate",
    "seed": "dotenvx run -- ts-node ./config/seed.ts"
  },
  "author": "Sabrina Demetrio",
  "license": "ISC",
  "keywords": ["api", "rest-api", "nodejs", "express", "prisma", "typescript", "backend", "sqlite"],
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "volleyball": "^1.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@dotenvx/dotenvx": "^1.71.0",
    "@prisma/config": "^7.9.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
