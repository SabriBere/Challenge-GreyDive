{
  "name": "back",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenvx run -- node --watch --watch-preserve-output -r ts-node/register index.ts",
    "build": "prisma generate && tsc",
    "start": "dotenvx run -- node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --ignore-path ../.prettierignore",
    "format:check": "prettier . --check --ignore-path ../.prettierignore",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:push": "dotenvx run -- prisma db push",
    "generate": "prisma generate",
    "seed": "dotenvx run -- ts-node ./config/seed.ts"
  },
  "author": "Sabrina Demetrio",
  "license": "ISC",
  "keywords": [
    "api",
    "rest-api",
    "nodejs",
    "express",
    "prisma",
    "typescript",
    "backend",
    "sqlite"
  ],
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "volleyball": "^1.5.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.69.1",
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
